<resources>
    <!-- Base application theme -->
    <style name="Theme.OpenBibleScholar" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/background_light</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.OpenBibleScholar.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/gold_primary</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="windowSplashScreenBrandingImage">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.OpenBibleScholar</item>
    </style>
</resources>
